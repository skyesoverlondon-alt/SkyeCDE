# Skye Mail Vault — template (set in Netlify UI, not committed with real values)

# --- REQUIRED ---
DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
JWT_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"
IP_HASH_SALT="REPLACE_WITH_LONG_RANDOM_SECRET"
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX"
NOTIFY_FROM_EMAIL="Skye Mail Vault <notify@yourdomain.com>"
PUBLIC_BASE_URL="https://YOUR-SITE.netlify.app"

# --- OPTIONAL: Admin Recovery (Break-glass) ---
# ADMIN_RECOVERY_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# ADMIN_RECOVERY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# ADMIN_RECOVERY_TOKEN="REPLACE_WITH_LONG_RANDOM_SECRET"

# --- OPTIONAL: VPS SMTP Bridge (preferred inbound) ---
SMTP_BRIDGE_SECRET="REPLACE_WITH_LONG_RANDOM_SECRET"

# --- OPTIONAL: Postmark inbound webhook (server-side encrypt at rest) ---
# INBOUND_DOMAIN="mail.yourdomain.com"
# INBOUND_PROVIDER="postmark"
# INBOUND_BASIC_USER="someuser"
# INBOUND_BASIC_PASS="somepass"
# INBOUND_SPAM_SCORE_MAX="7.0"
# INBOUND_MAX_TEXT_CHARS="200000"

# --- OPTIONAL: Cloudflare Turnstile bot defense (recommended for public send + thread) ---
# TURNSTILE_SITE_KEY="0x4AAAAAA..."
# TURNSTILE_SECRET_KEY="0x4AAAAAA..."

# --- OPTIONAL: Build ID shown in /health ---
# BUILD_ID="smv-enterprise-v1.1.0"

# --- OPTIONAL: SAML SP-initiated SSO (required if you enable SAML config) ---
# Provide your SP signing private key (PEM). Requests are signed using RSA-SHA256.
# SAML_SP_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- REQUIRED for Procurement Tier v1.3 (KMS-backed config + key management) ---
CONFIG_KMS_KEY_ID="REPLACE_WITH_AWS_KMS_KEY_ID_FOR_CONFIG_SECRETS"
AWS_REGION="us-east-1"
# AWS credentials are required unless your Netlify environment provides an IAM role equivalent:
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."

# --- SAML SP signing key (private) ---
SAML_SP_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

