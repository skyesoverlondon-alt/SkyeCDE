## 7. Netlify Functions → KaixuSI Wiring

The Netlify functions carry the secret internally — the browser never sees it:

```js
// netlify/functions/gateway-chat.js (simplified)
const WORKER = () => process.env.KAIXUSI_WORKER_URL.replace(/\/+$/, '');
const SECRET = () => process.env.KAIXUSI_SECRET;

export const handler = async (event) => {
  const body = JSON.parse(event.body || '{}');
  body.app_id = 'kaixu-superide'; // inject attribution

  const resp = await fetch(`${WORKER()}/v1/chat`, {
    method:  'POST',
    headers: {
      'Authorization': `Bearer ${SECRET()}`,
      'Content-Type':  'application/json'
    },
    body: JSON.stringify(body)
  });

  return { statusCode: resp.status, body: await resp.text(),
           headers: { 'Content-Type': 'application/json' } };
};
```

