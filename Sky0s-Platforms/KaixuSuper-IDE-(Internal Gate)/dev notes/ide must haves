# DATABASE SCHEMA SUMMARY (sql/schema.sql)
All 8 core tables + vector extension:

- users — id, email, password_hash, email_verified, mfa_secret, plan_id, stripe_customer_id, created_at
- sessions — id, user_id, device_info, last_active, revoked_at
- orgs — id, name, slug, plan, owner_id, sso_provider, sso_domain, sso_config
- org_members — org_id, user_id, role (owner/admin/editor/viewer)
- workspaces — id, name, user_id, org_id, files JSONB, created_at
- workspace_members — workspace_id, user_id, role
- invitations — id, email, org_id, workspace_id, role, token, accepted_at, expires_at
- plans — id, name, ai_call_limit, storage_gb, max_workspaces, max_members, stripe_price_id
- file_embeddings — workspace_id, file_path, chunk_index, chunk_text, embedding vector(768), updated_at
- ai_usage_log — user_id, workspace_id, model, prompt_tokens, completion_tokens, latency_ms, success, created_at
- audit_events — id, actor_id, event_type, resource_type, resource_id, metadata JSONB, created_at
- global_settings — key, value (used for kill switch etc.)

