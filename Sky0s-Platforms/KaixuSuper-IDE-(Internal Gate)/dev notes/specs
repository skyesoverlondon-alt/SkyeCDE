tasks
  GET    ?workspaceId=                             Auth: required
  POST   { workspaceId, title, assigneeId?, dueAt? }  Auth: required
  PATCH  { id, title?, status?, assigneeId? }      Auth: required
  DELETE { id }                                    Auth: required
  → Task tracker per workspace
  → { ok, tasks } | { ok, task } | { ok }

teams
  GET    ?orgId=                                   Auth: required
  POST   { orgId, name }                           Auth: required (admin+)
  PATCH  { id, name?, memberIds? }                 Auth: required (admin+)
  DELETE { id }                                    Auth: required (admin+)
  → Sub-teams within an org
