 4. ORG  (4 endpoints)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

org-create
  POST   { name }
  Auth:  required
  Rate:  5 orgs/hour per token
  → Creates org and inserts caller as owner
  → { ok, org }

org-list
  GET
  Auth:  required
  → Lists orgs the authed user belongs to
  → { ok, orgs }

org-members
  GET    ?orgId=         → list members            Auth: required (member+)
  PATCH  { orgId, userId, role }                   Auth: required (admin+)
  DELETE { orgId, userId }                         Auth: required (owner)
  → Manage org membership and roles
  → { ok, members } | { ok }

org-settings
  GET    ?orgId=         → view settings           Auth: required (any member)
  PATCH  { orgId, require_mfa?, sso_enabled?, sso_provider?, sso_domain? }
                                                   Auth: required (admin+)
  → Manage org security settings; allowlist-guarded (no arbitrary column writes)
  → { ok, settings, role } | { ok, settings }


