notifications
  GET    ?orgId=   → list notification prefs       Auth: required
  POST/action-based:
    action: 'upsert-pref'  { orgId, channel, config }
    action: 'send'         { orgId?, userId?, event, data }
  Auth:  required
  Channels: slack, email, webhook
