 FRONTEND MODULES  (load order matters)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

 1. db.js           — IndexedDB wrapper (offline file storage)
 2. ui.js           — UI primitives, toast, modal, theme
 3. editor.js       — CodeMirror editor integration
 4. explorer.js     — File explorer / tree
 5. search.js       — Full-text search (delegates to search.worker.js)
 6. outline.js      — Symbol outline panel
 7. problems.js     — Diagnostics / problems panel
 8. snippets.js     — Code snippet library
 9. templates.js    — Workspace template browser
10. commands.js     — Command palette
11. app.js          — Main app bootstrap, AI chat, toolbar, session handling
12. diff.js         — Diff viewer
13. scm.js          — Source control panel (git status, commit, push/pull)
14. collab.js       — Presence, comments, shared cursors
15. demo.js         — Demo mode / onboarding walkthrough
16. github.js       — GitHub connect / OAuth flow UI
17. admin.js        — Admin panel (platform admin only)

    search.worker.js — Web Worker for search indexing (loaded by search.js via
                       new Worker('search.worker.js'), no <script> tag needed)


