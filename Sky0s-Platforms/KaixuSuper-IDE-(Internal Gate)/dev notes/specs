 3. AI  (5 endpoints)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ai-edit
  POST   { workspaceId, filePath, instruction, model? }
  Auth:  required
  Gateway: https://kaixu67.skyesoverlondon.workers.dev
  Models:  kAIxU-flash (default, free/pro), kAIxU-pro (team/enterprise)
  → Streams AI-edited file content
  → { ok, result }

agent-memory
  GET    ?workspaceId=   → retrieve memories       Auth: required
  POST   { workspaceId, key, value }               Auth: required
  → Persist/retrieve arbitrary agent context per workspace
  → { ok, memories } | { ok }

embeddings
  GET    ?workspaceId=&q=&limit=5
  Auth:  required
  → Semantic search over workspace file chunks (pgvector)
  → { results: [{ path, chunk, score }] }

  POST   { action: 'sync', workspaceId, files: [{ path, content }] }
  Auth:  required
  → Chunk + embed files into file_embeddings table via kAIxU gateway
  → { synced: <count> }

chat-append
  POST   { workspaceId, role, content }
  Auth:  required
  → Appends a message to workspace chat history
  → { ok, message }

chat-list
  GET    ?workspaceId=&limit=50
  Auth:  required
  → Returns chat message history for a workspace
  → { ok, messages }


