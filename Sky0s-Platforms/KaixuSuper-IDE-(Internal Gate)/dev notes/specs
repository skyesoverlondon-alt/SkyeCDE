kAIxU SuperIDE — Technical Specifications
==========================================
Last updated: 2026-03-01
Version: 1.1.0
Endpoints: 58

All endpoints live at:  /.netlify/functions/<name>
Auth token format:      Authorization: Bearer <JWT>
JWT secret env var:     JWT_SECRET


━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
 1. AUTH  (9 endpoints)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

auth-signup
  POST   { email, password, name? }
  Auth:  none
  → Creates user, sends verification email (SendGrid)
  → { ok, token, user: { id, email, name } }

auth-login
  POST   { email, password }
  Auth:  none
  → Returns JWT on success; 401 if MFA required (returns mfa_required flag)
  → { ok, token, user } | { ok: false, mfa_required: true }

auth-me
  GET
  Auth:  required
  → Returns current user profile + org memberships
  → { ok, user, orgs }

auth-verify-email
  GET    ?token=<jwt>
  Auth:  required (token in query)
  → Marks email as verified
  → { ok }

auth-reset-request
  POST   { email }
  Auth:  none
  → Sends password reset email (SendGrid); dev mode returns dev_reset_url
  → { ok }

auth-reset-confirm
  POST   { token, password }
  Auth:  none
  → Resets password using signed reset token
  → { ok }

auth-mfa-setup
  GET    → generates TOTP secret + QR code URI     Auth: required
  POST   { code }  → verifies and enables MFA      Auth: required
  → GET: { ok, secret, otpauth_uri }
  → POST: { ok }

auth-mfa-verify
  POST   { email, password, code }
  Auth:  none
  → Second-factor login step; returns JWT on success
  → { ok, token, user }

auth-mfa-disable
  POST   { code }
  Auth:  required
  → Verifies current TOTP code then disables MFA
  → { ok }


