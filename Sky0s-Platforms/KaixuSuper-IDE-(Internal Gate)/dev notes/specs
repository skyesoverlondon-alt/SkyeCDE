 5. BILLING  (6 endpoints)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

billing-plans
  GET
  Auth:  required
  → Returns all plans from DB + current user subscription status
  → { ok, plans, current }

billing-create-session
  POST   { priceId, orgId? }
  Auth:  required
  → Creates Stripe Checkout session for subscription upgrade
  → { ok, url }

billing-portal
  POST   { orgId? }
  Auth:  required
  → Creates Stripe Customer Portal session for self-serve plan management
  → { ok, url }

billing-invoices
  GET    ?orgId=?
  Auth:  required
  → Lists Stripe invoices for user or org
  → { ok, invoices }

stripe-webhook
  POST   (Stripe-Signature header required)
  Auth:  none (Stripe HMAC signature verification)
  Env:   STRIPE_WEBHOOK_SECRET, STRIPE_SECRET_KEY
  Events handled:
    customer.subscription.created
    customer.subscription.updated
    customer.subscription.deleted
    invoice.paid
    invoice.payment_failed
  → { received: true }

usage-meter
  POST   { workspaceId, event, quantity? }
  Auth:  required
  → Records a usage event to usage_meters table (AI calls, file syncs, etc.)
  → { ok }


