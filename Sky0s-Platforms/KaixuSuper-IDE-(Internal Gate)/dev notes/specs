 2. WORKSPACE  (6 endpoints)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

ws-create
  POST   { name, orgId? }
  Auth:  required
  → Creates workspace, inserts owner membership
  → { ok, workspace }

ws-list
  GET    ?orgId=<id>?
  Auth:  required
  → Lists workspaces for the authed user (optionally filtered by org)
  → { ok, workspaces }

ws-get
  GET    ?id=<workspaceId>
  Auth:  required
  → Returns workspace metadata + files
  → { ok, workspace, files }

ws-save
  POST   { workspaceId, files: [{ path, content }] }
  Auth:  required
  → Upserts file contents for a workspace
  → { ok, saved }

ws-admin
  GET/POST/DELETE
  Auth:  required (admin or owner role)
  → Manage workspace-level admin settings (rename, delete, transfer)

workspace-share
  GET    ?workspaceId=   → list shares             Auth: required
  POST   { workspaceId, userId, role }             Auth: required
  DELETE { workspaceId, userId }                   Auth: required
  → Manage workspace membership/sharing
  → { ok, shares } | { ok }


