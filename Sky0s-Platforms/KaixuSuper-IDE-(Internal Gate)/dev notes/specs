 6. GITHUB  (4 endpoints)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

github-connect
  GET    ?workspaceId=   → retrieve connection      Auth: required
  DELETE { workspaceId } → remove connection        Auth: required
  (POST handled by github-status flow)
  → { ok, connection } | { ok }

github-pull
  POST   { workspaceId, repo, branch?, path? }
  Auth:  required
  → Pulls files from GitHub repo into workspace via GitHub API
  → { ok, files: [{ path, content }] }

github-push
  POST   { workspaceId, repo, branch, message?, files }
  Auth:  required
  → Pushes workspace files to GitHub using Git Trees API
  → { ok, sha, url }

github-status
  GET    ?workspaceId=
  Auth:  required
  → Returns GitHub connection health + ahead/behind commit count
  → { ok, connected, repo, ahead, behind }


