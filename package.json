{
  "private": true,
  "version": "1.69.0",
  "license": "MIT",
  "author": "Rob Moran <github@thegecko.org>",
  "homepage": "https://github.com/SkyeCDE/SkyeCDE#readme",
  "bugs": {
    "url": "https://github.com/SkyeCDE/SkyeCDE/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SkyeCDE/SkyeCDE.git"
  },
  "engines": {
    "yarn": ">=1.7.0 <2",
    "node": ">=22"
  },
  "devDependencies": {
    "@eclipse-dash/nodejs-wrapper": "^0.0.1",
    "@theia/cli": "1.70.0-next.11",
    "@types/yargs": "17.0.7",
    "@typescript-eslint/eslint-plugin": "^4.25.0",
    "@typescript-eslint/eslint-plugin-tslint": "^4.25.0",
    "@typescript-eslint/parser": "^4.25.0",
    "eslint": "^7.27.0",
    "eslint-plugin-deprecation": "1.2.1",
    "eslint-plugin-import": "^2.23.3",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-no-unsanitized": "^3.1.5",
    "eslint-plugin-react": "^7.23.2",
    "find-git-repositories": "0.2.2",
    "lerna": "^6.0.1",
    "node-gyp": "^11.4.0",
    "rimraf": "^2.7.1",
    "ts-node": "^10.0.0",
    "type-fest": "^0.20.2",
    "yargs": "17.2.1"
  },
  "scripts": {
    "clean": "npm exec -- lerna run clean && npm exec -- rimraf node_modules",
    "build": "npm run build:extensions && npm run build:applications",
    "build:dev": "npm run build:extensions && npm run build:applications:dev",
    "browser:build": "node scripts/browser-build.js",
    "browser:start": "node scripts/browser-start.js",
    "icons:generate": "node scripts/generate-brand-icons.js all",
    "build:applications": "node scripts/run-npm-in.js applications/browser build:prod && node scripts/run-npm-in.js applications/electron build:prod",
    "build:applications:dev": "node scripts/run-npm-in.js applications/browser build && node scripts/run-npm-in.js applications/electron build",
    "build:applications:next": "node scripts/run-npm-in.js applications/electron-next build:prod",
    "build:extensions": "node scripts/run-npm-in.js theia-extensions/launcher build && node scripts/run-npm-in.js theia-extensions/product build && node scripts/run-npm-in.js theia-extensions/updater build",
    "download:plugins": "npm exec -- theia download:plugins --rate-limit=15 --parallel=false && npm run permissions:writeable",
    "package:applications": "node scripts/run-npm-in.js applications/electron package",
    "package:applications:preview": "node scripts/run-npm-in.js applications/electron package:preview",
    "package:applications:prod": "node scripts/run-npm-in.js applications/electron deploy",
    "package:applications:next": "node scripts/run-npm-in.js applications/electron-next package",
    "permissions:writeable": "ts-node scripts/make-files-writeable.ts plugins",
    "watch": "npm exec -- lerna run --parallel watch",
    "test": "npm exec -- lerna run test",
    "electron": "node scripts/run-npm-in.js applications/electron",
    "browser": "node scripts/run-npm-in.js applications/browser",
    "update:theia": "ts-node scripts/update-theia-version.ts",
    "update:theia:children": "npm exec -- lerna run update:theia -- ",
    "update:next": "ts-node scripts/update-theia-version.ts next && npm exec -- lerna run update:next",
    "lint": "eslint --ext js,jsx,ts,tsx scripts && npm exec -- lerna run lint",
    "lint:fix": "eslint --ext js,jsx,ts,tsx scripts --fix && npm exec -- lerna run lint:fix",
    "license:check": "npm exec -- dash-licenses-wrapper --configFile=./configs/license-check-config.json",
    "license:check:review": "npm exec -- dash-licenses-wrapper --configFile=./configs/license-check-config.json --review",
    "policy:check:ai-providers": "node scripts/check-disallowed-ai-providers.js",
    "policy:check:runtime-ai-routing": "node scripts/check-runtime-ai-routing.js",
    "postinstall": "theia-patch"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "vscode-builtin-extensions": "https://github.com/eclipse-theia/vscode-builtin-extensions/releases/download/1.104.0/vscode-builtin-extensions-1.104.0.tar.gz",
    "vscjava.vscode-java-pack": "https://open-vsx.org/api/vscjava/vscode-java-pack/0.30.5/file/vscjava.vscode-java-pack-0.30.5.vsix",
    "vscjava.vscode-java-dependency": "https://open-vsx.org/api/vscjava/vscode-java-dependency/0.27.0/file/vscjava.vscode-java-dependency-0.27.0.vsix"
  },
  "theiaPluginsExcludeIds": [
    "ms-vscode.js-debug-companion",
    "VisualStudioExptTeam.vscodeintellicode",
    "vscode.extension-editing",
    "vscode.github",
    "vscode.github-authentication",
    "vscode.microsoft-authentication"
  ],
  "workspaces": [
    "applications/*",
    "theia-extensions/*"
  ],
  "resolutions": {
    "@types/puppeteer": "^5.4.0",
    "@yarnpkg/parsers": "3.0.0-rc.44",
    "**/multer": "1.4.4-lts.1",
    "**/nan": "2.25.0",
    "**/cpu-features": "0.0.9",
    "**/perfect-scrollbar": "1.5.5",
    "**/node-abi": "4.14.0"
  }
}
